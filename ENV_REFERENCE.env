# ─────────────────────────────────────────────────────────────────
# FaceCheck — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────
# Copy each block into the corresponding service directory as .env
# ─────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════
# backend/.env
# ═══════════════════════════════════════════

DATABASE_URL="postgresql://faceadmin:facepass123@localhost:5432/face_attendance"

# Python face service URL
PYTHON_SERVICE_URL="http://localhost:8001"

# JWT — change this to a long random string in production!
JWT_SECRET="change_me_to_something_long_and_random_in_production"
JWT_EXPIRES_IN="7d"

# NestJS server port
PORT=3000


# ═══════════════════════════════════════════
# python-service/.env  (optional — the service
#  reads these but has sane defaults already)
# ═══════════════════════════════════════════

PYTHONUNBUFFERED=1

# Where to cache the downloaded InsightFace model
# Defaults to ./models inside the service directory
MODEL_DIR="./models"

# Host / port
HOST="0.0.0.0"
PORT=8001

# Face match cosine-similarity threshold (0.0 – 1.0)
# Lower = more permissive, Higher = stricter
# 0.40 is a good starting point for buffalo_sc on CPU
MATCH_THRESHOLD=0.40


# ═══════════════════════════════════════════
# frontend/.env  (Vite reads VITE_* prefix)
# ═══════════════════════════════════════════

# Point at the NestJS backend
VITE_API_URL="http://localhost:3000"
